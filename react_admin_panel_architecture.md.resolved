### 1.6 Data Models

#### User

```typescript
interface User {
  id: string;
  fullName: string;          // user_full_name on API
  email: string;
  phone: string;
  password: string;
  gender?: string;
  status: "PENDING_PHONE" | "PENDING_EMAIL" | "PENDING_APPROVAL" | "ACCEPTED" | "REJECTED" | "BLOCKED";
  phoneVerified: boolean;
  emailVerified: boolean;
}
```

#### Listing (Vehicle)

```typescript
interface Listing {
  lst_id: string;
  lst_title: string;
  lst_description?: string;
  lst_type: "AUCTION" | "BUY_NOW";
  lst_price: number;
  lst_current_bid?: number;
  lst_min_increment?: number;
  lst_bid_count: number;
  lst_view_count: number;
  lst_auction_end?: string;   // ISO date
  lst_status: string;
  lst_category_id: string;
  lst_created_at: string;
  category?: { cat_id: string; cat_name: string };
  seller?: { user_id: string; user_full_name: string };
  images?: { url?: string; file_url?: string }[];
}
```

#### Deal

```typescript
interface Deal {
  id: string;
  vehicle: string;
  vehicleImage: string;
  status: "WON" | "PENDING_PAYMENT" | "COMPLETED" | "LOST";
  price: number;
  date: string;
  type: "AUCTION" | "BUY_NOW";
}
```

#### Category

```typescript
interface Category {
  cat_id: string;
  cat_name: string;
}
```

#### Subscription

```typescript
interface Subscription {
  status: "ACTIVE" | "EXPIRED" | "NONE";
  plan: "BASIC" | "STANDARD" | "PREMIUM";
  remainingListings: number;
  totalListings: number;
  expiresAt: string;
  price: number;
}
```

#### Sell Request

```typescript
interface SellRequest {
  requestId: string;
  title: string;
  description?: string;
  category: string;
  listingType: "AUCTION" | "BUY_NOW";
  basePrice: number;
  status: "PENDING_ADMIN_REVIEW" | "APPROVED" | "REJECTED";
}
```

